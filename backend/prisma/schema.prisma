datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  GYM_OWNER
  STAFF
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TransactionStatus {
  PENDING
  AWAITING_VERIFICATION
  PAID
  FAILED
  REJECTED
  EXPIRED
}

enum PaymentMode {
  MANUAL_UPI
  RAZORPAY
}

enum ReminderType {
  EXPIRING_7
  EXPIRING_3
  EXPIRING_1
  EXPIRED_TODAY
  EXPIRED_3
  EXPIRED_7
}

enum WhatsappSessionStatus {
  CONNECTED
  DISCONNECTED
  INITIALIZING
  QR_READY
}

enum WhatsAppDisplayNameStatus {
  PENDING_REVIEW
  APPROVED
  DECLINED
  REGISTERING
  REGISTERED
  REGISTRATION_FAILED
}

model Gym {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  // WhatsApp Cloud API Integration
  whatsapp_connected       Boolean           @default(false)
  whatsapp_phone_number    String?
  whatsapp_phone_number_id String?
  whatsapp_waba_id         String?
  whatsapp_business_id     String?
  whatsapp_access_token    String?           // Encrypted string
  whatsappStatus             String?           @default("disconnected")
  whatsappVerifiedAt         DateTime?
  whatsappLastError          String?
  whatsappVerificationStatus String?           @default("NOT_VERIFIED")
  whatsappQualityRating      String?           @default("UNKNOWN")
  whatsappMessagingTier      String?           @default("UNKNOWN")
  whatsappVerifiedName       String?
  whatsappDisplayPhoneNumber String?
  whatsappNameStatus         WhatsAppDisplayNameStatus?
  pendingDisplayName         String?
  pendingNameStatus          WhatsAppDisplayNameStatus?
  lastNameChangeRequestAt    DateTime?
  lastNameApprovedAt         DateTime?
  lastRegistrationAttemptAt  DateTime?
  registrationError          String?
  displayNameRetryCount      Int               @default(0)
  displayNameLockedUntil     DateTime?

  users            GymUser[]
  members          Member[]
  plans            MembershipPlan[]
  memberships      Membership[]
  transactions     Transaction[]
  whatsappSession  WhatsappSession?
  chatbotSettings  ChatbotSettings?
  paymentSettings  PaymentSettings?
  renewalLogs      RenewalLog[]
  notifications    Notification[]
  invoices         Invoice[]
  auditLogs        AuditLog[]
  whatsappMessages  WhatsAppMessage[]
  whatsappTemplates WhatsAppTemplate[]
  whatsappDisplayNameHistory WhatsAppDisplayNameHistory[]
}

model WhatsAppDisplayNameHistory {
  id                  String                    @id @default(uuid())
  gymId               String
  requestedByUserId   String?

  phoneNumberId       String
  graphApiVersion     String

  oldName             String?
  newName             String
  status              WhatsAppDisplayNameStatus
  isActive            Boolean                   @default(true)

  metaResponse        Json?

  requestedAt         DateTime                  @default(now())
  approvedAt          DateTime?
  registeredAt        DateTime?
  rejectionReason     String?
  
  processedByWorker   Boolean                   @default(false)
  workerAttempts      Int                       @default(0)

  gym                 Gym                       @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model GymUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(STAFF)
  gymId        String?   // Nullable for Super Admins
  gym          Gym?      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AuditLog[]
}

enum CallPermissionStatus {
  UNKNOWN
  PENDING
  GRANTED
  DENIED
  REVOKED
}

model Member {
  id               String            @id @default(uuid())
  memberName       String
  whatsappName     String?
  phone            String            // WhatsApp Number, unique per gym
  email            String?
  address          String?
  dob              DateTime?
  emergencyContact String?
  notes            String?
  isBotDisabled    Boolean           @default(false) // For Human Takeover
  blockedAt        DateTime?
  
  // Call Permission Tracking
  callPermissionStatus      CallPermissionStatus @default(UNKNOWN)
  callPermissionUpdatedAt   DateTime?
  callPermissionVerifiedAt  DateTime?
  callPermissionRequestedAt DateTime?
  callPermissionGrantedAt   DateTime?
  callPermissionRevokedAt   DateTime?
  callPermissionRequestCount Int                 @default(0)

  gymId            String
  gym              Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  memberships      Membership[]
  transactions     Transaction[]
  renewalLogs      RenewalLog[]
  notifications    Notification[]

  @@unique([gymId, phone])
}

model MembershipPlan {
  id           String       @id @default(uuid())
  name         String
  description  String?
  price        Float
  durationDays Int          // 30, 90, 180, 365, etc.
  gymId        String
  gym          Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  memberships  Membership[]
  transactions Transaction[]
}

model Membership {
  id         String           @id @default(uuid())
  memberId   String
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId     String
  plan       MembershipPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  status     MembershipStatus @default(ACTIVE)
  gymId      String
  gym        Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  
  renewalLogs RenewalLog[]
}

model Transaction {
  id            String            @id @default(uuid())
  amount        Float
  status        TransactionStatus @default(PENDING)
  paymentMode   PaymentMode
  referenceId   String?           // UPI Txn Ref or Razorpay Order ID
  paymentDetails Json?            // Store full gateway payload
  memberId      String
  member        Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId        String
  plan          MembershipPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  gymId         String
  gym           Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  
  invoice       Invoice?
}

model WhatsappSession {
  id          String                @id @default(uuid())
  sessionData String?               // Encrypted session JSON
  qrCode      String?               // Current QR text to display
  status      WhatsappSessionStatus @default(DISCONNECTED)
  gymId       String                @unique
  gym         Gym                   @relation(fields: [gymId], references: [id], onDelete: Cascade)
  updatedAt   DateTime              @updatedAt
}

model ChatbotSettings {
  id               String   @id @default(uuid())
  welcomeMessage   String   @default("Welcome to {{gym_name}}!\n\n1. My Membership\n2. Renew Membership\n3. View Plans\n4. Contact Gym\n5. Offers")
  isAiModeEnabled  Boolean  @default(false)
  aiKnowledgeBase  String?  // RAG Source Text (timings, trainers, FAQs, etc.)
  gymId            String   @unique
  gym              Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  updatedAt        DateTime @updatedAt
}

model PaymentSettings {
  id                 String   @id @default(uuid())
  upiId              String?
  upiName            String?
  razorpayKeyId      String?
  razorpayKeySecret  String?
  isRazorpayEnabled  Boolean  @default(false)
  gymId              String   @unique
  gym                Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  updatedAt          DateTime @updatedAt
}

model RenewalLog {
  id           String       @id @default(uuid())
  memberId     String
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  membershipId String
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  reminderType ReminderType
  status       String       // SENT, FAILED
  gymId        String
  gym          Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  sentAt       DateTime     @default(now())
}

model Notification {
  id             String   @id @default(uuid())
  type           String   // ACTIVATION, RENEWAL, PAYMENT_RECEIVED, PAYMENT_REJECTED, REMINDER
  title          String
  message        String
  recipientPhone String
  status         String   // PENDING, SENT, FAILED
  gymId          String
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  memberId       String
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Invoice {
  id            String      @id @default(uuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  invoiceNumber String      @unique
  pdfPath       String?     // Local path or cloud URL
  gymId         String
  gym           Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g., "MEMBER_CREATE", "TRANSACTION_APPROVE"
  details   String
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  userId    String?
  user      GymUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model WhatsAppMessage {
  id             String          @id @default(uuid())
  gymId          String
  gym            Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  messageId      String          @unique // wamid.xxxxx
  senderPhone    String
  recipientPhone String
  text           String
  direction      String          // INBOUND, OUTBOUND, ECHO
  status         String          // SENT, DELIVERED, READ, FAILED
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  events         WhatsAppEvent[]

  @@map("WhatsAppMessages")
}

model WhatsAppEvent {
  id         String          @id @default(uuid())
  messageId  String
  message    WhatsAppMessage @relation(fields: [messageId], references: [messageId], onDelete: Cascade)
  eventType  String          // SENT, DELIVERED, READ, FAILED
  timestamp  DateTime
  rawPayload Json
  createdAt  DateTime        @default(now())

  @@map("WhatsAppEvents")
}

model WhatsAppTemplate {
  id             String   @id @default(uuid())
  gymId          String
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  templateName   String   // local and meta name: membership_expiry, welcome_member, etc.
  metaTemplateId String?  // ID returned from Meta
  language       String   @default("en_US")
  category       String   @default("UTILITY")
  status         String   // PENDING, APPROVED, REJECTED, ACTIVE
  components     Json     // template structures
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([gymId, templateName])
  @@map("WhatsAppTemplates")
}
